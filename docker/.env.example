# fleet-gateway — environment variables
# Copy to .env and fill in your keys.
# Free tiers available for all services below.

# ── Ports ─────────────────────────────────────────────────────
FLEET_PORT=4000
SEARXNG_PORT=8888
FIRECRAWL_PORT=3002

# ── SearXNG ───────────────────────────────────────────────────
SEARXNG_SECRET_KEY=change-me-to-a-random-string

# ── LLM API Keys (add at least one to get started) ───────────

# Groq (FREE) — https://console.groq.com
# 30 req/min, Llama 3.3 70B and more
GROQ_API_KEY=

# Cerebras (FREE, 1M tok/day) — https://cloud.cerebras.ai
# Fastest inference: Qwen3-235B at ~2600 t/s
CEREBRAS_API_KEY=

# SambaNova (FREE) — https://cloud.sambanova.ai
# Qwen3-235B, DeepSeek V3, Llama 3.3 70B
SAMBANOVA_API_KEY=

# Mistral (FREE experiment tier) — https://console.mistral.ai
# 2 req/min, 1B tok/month. Best for Italian, proofreading.
MISTRAL_API_KEY=

# Google Gemini (FREE tier) — https://aistudio.google.com
# 15 req/min free, Gemini 2.5 Flash/Pro
GEMINI_API_KEY=

# OpenRouter (FREE models available) — https://openrouter.ai
# Many free models: Qwen3-Coder, Hermes 405B, Mistral, etc.
OPENROUTER_API_KEY=

# NVIDIA NIM (FREE, 1000 calls/month) — https://build.nvidia.com
# Nemotron, Qwen3.5-122B, Llama 3.3 Nemotron
NVIDIA_API_KEY=

# ── Paid (optional) ───────────────────────────────────────────

# OpenAI — https://platform.openai.com
OPENAI_API_KEY=

# Anthropic Claude — https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── Local models (optional, add when you have hardware) ───────
# If you're running Ollama locally:
# OLLAMA_URL=http://localhost:11434
#
# If you're running llama.cpp server:
# LOCAL_LLM_URL=http://localhost:8080
