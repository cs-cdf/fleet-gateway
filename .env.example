# fleet-gateway — environment variables
# Copy to .env and fill in your keys.
# The gateway auto-discovers backends from the keys you provide.
# You need at least ONE key to get started.

# ── Free Tiers (recommended starting point) ──────────────────

# Cerebras — 1M tok/day FREE — https://cloud.cerebras.ai
# Models: Qwen3-235B (2600 t/s!), Llama3.1-8B
CEREBRAS_API_KEY=

# Groq — 30 req/min FREE — https://console.groq.com
# Models: Llama 3.3 70B, Llama3-70B, Mixtral 8x7B
GROQ_API_KEY=

# SambaNova — FREE — https://cloud.sambanova.ai
# Models: Qwen3-235B, DeepSeek V3.2, Llama 3.3 70B
SAMBANOVA_API_KEY=

# Mistral — 2 req/min, 1B tok/month FREE — https://console.mistral.ai
# Models: Mistral Large, Codestral (best for Italian/French/coding)
MISTRAL_API_KEY=

# Google Gemini — 15 req/min, 1M tok/day FREE — https://aistudio.google.com
# Models: Gemini 2.5 Flash (vision), Gemini 2.5 Pro
GEMINI_API_KEY=

# OpenRouter — 50 req/day FREE models — https://openrouter.ai
# Free models: Qwen3-Coder, Hermes 405B, Mistral 24B, DeepSeek R1
OPENROUTER_API_KEY=

# NVIDIA NIM — 1000 calls/month FREE — https://build.nvidia.com
# Models: Nemotron 120B, Qwen3.5-122B, Llama 3.3 Nemotron
NVIDIA_API_KEY=

# ── Paid (optional) ───────────────────────────────────────────

# OpenAI — https://platform.openai.com
OPENAI_API_KEY=

# Anthropic Claude — https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── Web Tools (optional) ──────────────────────────────────────

# SearXNG — self-hosted web search (no key needed for self-hosted)
# docker run -d -p 8888:8080 searxng/searxng
SEARXNG_URL=

# Firecrawl — web scraping (no key needed for self-hosted)
# docker compose up firecrawl-api redis -d (see docker/docker-compose.yml)
FIRECRAWL_URL=
FIRECRAWL_API_KEY=

# ── Gateway Server ─────────────────────────────────────────────
FLEET_PORT=4000
FLEET_HOST=0.0.0.0

# ── Config file (optional override) ───────────────────────────
# FLEET_GATEWAY_CONFIG=/path/to/config.yaml
